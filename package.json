{
  "name": "nimbus-os",
  "version": "0.3.8-alpha",
  "description": "Personal AI OS — autonomous, soul-driven agent with cross-session memory",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "author": {
    "name": "Hiep Hoang Trung",
    "email": "work.hiepht@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/0xsyncroot/nimbus-os.git"
  },
  "homepage": "https://github.com/0xsyncroot/nimbus-os",
  "keywords": ["ai", "agent", "llm", "personal-assistant", "bun", "typescript", "anthropic", "openai", "mcp", "cli"],
  "bin": {
    "nimbus": "./src/cli.ts"
  },
  "files": [
    "src/**/*.ts",
    "src/**/*.json",
    "specs/**/*.md",
    "docs/**/*.md",
    "examples/**/*.md",
    "scripts/**/*.ts",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "CLAUDE.md",
    "tsconfig.json",
    "bunfig.toml"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "bun run src/cli.ts",
    "dev": "bun --watch run src/cli.ts",
    "test": "bun test",
    "test:e2e": "bun test tests/e2e",
    "test:non-http": "bun test $(find tests -type f -name '*.test.ts' ! -path 'tests/channels/http/*')",
    "test:http": "bun test tests/channels/http/",
    "test:all": "bun run test:non-http && bun run test:http",
    "typecheck": "tsc --noEmit",
    "lint": "bunx eslint src/ tests/",
    "format": "bunx prettier --write src/ tests/ specs/",
    "build": "bun build src/cli.ts --target=bun --outfile=dist/nimbus.js",
    "spec": "bun run scripts/spec/index.ts",
    "compile:linux-x64": "bun build --compile --target=bun-linux-x64 src/cli.ts --outfile dist/nimbus-linux-x64",
    "compile:linux-arm64": "bun build --compile --target=bun-linux-arm64 src/cli.ts --outfile dist/nimbus-linux-arm64",
    "compile:darwin-x64": "bun build --compile --target=bun-darwin-x64 src/cli.ts --outfile dist/nimbus-darwin-x64",
    "compile:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 src/cli.ts --outfile dist/nimbus-darwin-arm64",
    "compile:windows-x64": "bun build --compile --target=bun-windows-x64 src/cli.ts --outfile dist/nimbus-windows-x64.exe"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@modelcontextprotocol/sdk": "^1.10.2",
    "@mozilla/readability": "^0.5.0",
    "graceful-fs": "^4.2.11",
    "gray-matter": "^4.0.3",
    "marked": "^18.0.0",
    "openai": "^4.76.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "shell-quote": "^1.8.1",
    "turndown": "^7.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/shell-quote": "^1.7.5",
    "@types/turndown": "^5.0.4",
    "typescript": "^5.7.2"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
